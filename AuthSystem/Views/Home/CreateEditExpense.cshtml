@{
    ViewData["Title"] = "Dodaj / Edytuj";
}

@model AuthSystem.Models.Expense

<div class="text-center">
    <h1 class="display-4">Dodaj lub edytuj wydatki</h1>
</div>

<form asp-action="CreateEditExpenseForm" asp-controller="Home" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label for="Value">Kwota $</label>
        <input class="form-control" type="number" asp-for="Value" step="0.01" />
        <span asp-validation-for="Value" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="Description">Opis</label>
        <input class="form-control" type="text" asp-for="Description" />
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary mt-4">Ok</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}